---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { getFolderTitle, getImageUrl, R2_DOMAIN } from "../../lib/constants";

const { folder } = Astro.params;

// Get all albums in this folder by checking the slug prefix
const allAlbums = await getCollection("albums");
const folderAlbums = allAlbums
    .filter((album) => album.slug.startsWith(`${folder}/`))
    .sort((a, b) => b.data.order - a.data.order);

if (folderAlbums.length === 0) {
    return Astro.redirect("/404");
}

const folderTitle = getFolderTitle(folder!);
const isDev = import.meta.env.DEV;
---

<Layout title={`${folderTitle} - RIVERBED`}>
    <main class="mx-auto px-2 py-8">
        <div class="albums-grid">
            {
                folderAlbums.map((album) => {
                                    const albumSlug = album.slug.split("/")[1];
                    const resolvedCoverKey = album.data.coverKey.includes("/")
                        ? album.data.coverKey
                        : `${album.slug}/${album.data.coverKey}`;
                    const coverUrl = getImageUrl(resolvedCoverKey);
                    const fallbackUrl = `${R2_DOMAIN}/${resolvedCoverKey}`;
                    return (
                        <div class="album-card group">
                            <a
                                href={`/${folder}/${albumSlug}`}
                                class="album-link"
                            >
                                <div class="album-cover">
                                    <img
                                        src={coverUrl}
                                        alt={album.data.title}
                                        loading="lazy"
                                        style={`--zoom: ${album.data.coverZoom ?? 1}; --ox: ${album.data.coverOffset?.x ?? 50}%; --oy: ${album.data.coverOffset?.y ?? 50}%;`}
                                        onerror={
                                            isDev
                                                ? `this.onerror=null; this.src='${fallbackUrl}';`
                                                : undefined
                                        }
                                    />
                                    <div class="album-overlay">
                                        <h2 class="album-title">
                                            {album.data.title}
                                        </h2>
                                    </div>
                                </div>
                            </a>
                        </div>
                    );
                })
            }
        </div>
    </main>
</Layout>

<script>
    const initAlbumCards = () => {
        const cards = document.querySelectorAll(".album-card");

        cards.forEach((card) => {
            const link = card.querySelector(".album-link");

            card.addEventListener("click", (e) => {
                const isMobile = window.matchMedia(
                    "(max-width: 768px) and (hover: none)",
                ).matches;
                if (!isMobile) return;

                if (!card.classList.contains("show-info")) {
                    // First tap: show info
                    e.preventDefault();

                    // Close other cards
                    cards.forEach((c) => c.classList.remove("show-info"));

                    card.classList.add("show-info");
                } else {
                    // Second tap: follow link (natural behavior)
                }
            });
        });

        // Close when clicking outside
        document.addEventListener("click", (e) => {
            if (!(e.target as Element).closest(".album-card")) {
                cards.forEach((c) => c.classList.remove("show-info"));
            }
        });
    };

    initAlbumCards();
    document.addEventListener("astro:after-swap", initAlbumCards);
</script>

<style>
    .albums-grid {
        display: grid;
        grid-template-columns: repeat(var(--cols, 3), 1fr);
        gap: 0.5rem;
        margin: 0 auto;
    }

    @media (max-width: 1024px) {
        .albums-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 640px) {
        .albums-grid {
            grid-template-columns: 1fr;
        }
    }

    .album-card {
        position: relative;
    }

    .album-link {
        text-decoration: none;
        color: inherit;
        display: block;
    }

    .album-cover {
        position: relative;
        width: 100%;
        aspect-ratio: 177/100;
        overflow: hidden;
        background: #1a1a1a;
    }

    .album-cover img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: var(--ox) var(--oy);
        transform: scale(var(--zoom));
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), object-position 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .album-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        transition: all 0.4s ease;
        background: rgba(255, 255, 255, 0);
        opacity: 0;
        z-index: 10;
        pointer-events: none;
    }

    .album-title {
        font-family: "Noto Sans TC", "Noto Sans JP", sans-serif;
        font-size: 1.25rem;
        font-weight: 400;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        text-align: center;
        color: #111827;
        transform: translateY(10px);
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        z-index: 20;
    }

    .album-card.show-info .album-overlay {
        opacity: 1;
        background: rgba(255, 255, 255, 0.7);
    }

    .album-card.show-info .album-title {
        opacity: 1;
        transform: translateY(0);
    }

    @media (hover: hover) {
        .album-card:hover .album-cover img {
            transform: scale(calc(var(--zoom) * 1.05));
        }

        .album-card:hover .album-overlay {
            opacity: 1;
            background: rgba(255, 255, 255, 0.6);
        }

        .album-card:hover .album-title {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
