---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Row from "../../components/Row.astro";
import Photo from "../../components/Photo.astro";
import PhotoCarousel from "../../components/PhotoCarousel.astro";
import Text from "../../components/Text.astro";

const { folder, album } = Astro.params;

// Get all albums and find the matching one by its combined slug
const allAlbums = await getCollection("albums");
const albumEntry = allAlbums.find((a) => a.slug === `${folder}/${album}`);

if (!albumEntry) {
    return Astro.redirect("/404");
}

// Get the Content component from the entry
let Content;
try {
    console.log("Rendering album:", albumEntry.id, "Folder:", folder);
    const rendered = await albumEntry.render();
    Content = rendered.Content;
} catch (e) {
    console.error("Error rendering album:", e);
    throw e;
}
---

<Layout title={`${albumEntry.data.title} - RIVERBED`}>
    <div class="fixed bottom-8 right-8 z-40 flex flex-col gap-3">
        <button
            onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
            class="group text-zinc-500 hover:text-white transition-all duration-300 opacity-0 translate-y-4 pointer-events-none"
            id="back-to-top"
            aria-label="Scroll to top"
        >
            <div
                class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center group-hover:border-white/30 transition-colors bg-white/20 backdrop-blur-sm"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="m18 15-6-6-6 6"></path></svg
                >
            </div>
        </button>
        <button
            onclick="window.scrollTo({top: document.body.scrollHeight, behavior: 'smooth'})"
            class="group text-zinc-500 hover:text-white transition-all duration-300 opacity-0 translate-y-4 pointer-events-none"
            id="scroll-to-bottom"
            aria-label="Scroll to bottom"
        >
            <div
                class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center group-hover:border-white/30 transition-colors bg-white/20 backdrop-blur-sm"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="m6 9l6 6 6-6"></path></svg
                >
            </div>
        </button>
    </div>

    <div class="py-4">
        <div class="mb-8 text-center">
            <h1
                class="text-xl font-sans tracking-widest uppercase mb-1"
            >
                {albumEntry.data.title}
            </h1>
            {albumEntry.data.info && (
                <p class="text-sm text-zinc-500 font-light tracking-wider uppercase">
                    {albumEntry.data.info}
                </p>
            )}
        </div>

        <article
            class="album-content"
            style={albumEntry.data.gap ? `--album-block-gap: ${albumEntry.data.gap}` : undefined}
        >
            <Content components={{ Row, Photo, Text, PhotoCarousel }} />
        </article>
    </div>
</Layout>

<style>
    .album-content {
        width: 100%;
        display: flex;
        flex-direction: column;
    }

    /* Apply the gap to all blocks except the last one */
    .album-content > :global(*) {
        margin-bottom: var(--album-block-gap, 0.5rem);
    }

    .album-content > :global(*:last-child) {
        margin-bottom: 0;
    }

    .album-content :global(h2) {
        font-size: 1.5rem;
        font-weight: 600;
        margin: 2rem 0 1rem;
    }

    .album-content :global(p) {
        margin: 0.5rem 0;
        line-height: 1.6;
    }
</style>

<script>
    const handleScroll = () => {
        const backToTop = document.getElementById("back-to-top");
        const scrollToBottom = document.getElementById("scroll-to-bottom");

        if (backToTop) {
            if (window.scrollY > 300) {
                backToTop.classList.remove("opacity-0", "translate-y-4", "pointer-events-none");
                backToTop.classList.add("opacity-100", "translate-y-0", "pointer-events-auto");
            } else {
                backToTop.classList.add("opacity-0", "translate-y-4", "pointer-events-none");
                backToTop.classList.remove("opacity-100", "translate-y-0", "pointer-events-auto");
            }
        }

        if (scrollToBottom) {
            const isNearBottom = (window.scrollY + window.innerHeight) >= (document.documentElement.scrollHeight - 300);
            if (!isNearBottom) {
                scrollToBottom.classList.remove("opacity-0", "translate-y-4", "pointer-events-none");
                scrollToBottom.classList.add("opacity-100", "translate-y-0", "pointer-events-auto");
            } else {
                scrollToBottom.classList.add("opacity-0", "translate-y-4", "pointer-events-none");
                scrollToBottom.classList.remove("opacity-100", "translate-y-0", "pointer-events-auto");
            }
        }
    };

    window.addEventListener("scroll", handleScroll);
    document.addEventListener("astro:after-swap", handleScroll);
    handleScroll();
</script>
