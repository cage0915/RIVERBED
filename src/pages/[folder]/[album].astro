---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Row from "../../components/Row.astro";
import Photo from "../../components/Photo.astro";
import PhotoCarousel from "../../components/PhotoCarousel.astro";
import Text from "../../components/Text.astro";

const slugifySectionTitle = (value: string) => value
    .toLowerCase()
    .normalize("NFKD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9\s-]/g, "")
    .trim()
    .replace(/\s+/g, "-") || "section";

const extractTitleSections = (body: string) => {
    const sections: Array<{ id: string; label: string }> = [];
    const slugCounts = new Map<string, number>();
    const titleBlockPattern = /<Text\b(?=[^>]*\bsize="title")[^>]*>([\s\S]*?)<\/Text>/g;

    for (const match of body.matchAll(titleBlockPattern)) {
        const label = match[1]
            .replace(/<[^>]+>/g, " ")
            .replace(/\s+/g, " ")
            .trim();

        if (!label) {
            continue;
        }

        const baseSlug = slugifySectionTitle(label);
        const nextCount = (slugCounts.get(baseSlug) ?? 0) + 1;
        slugCounts.set(baseSlug, nextCount);

        sections.push({
            id: nextCount === 1 ? baseSlug : `${baseSlug}-${nextCount}`,
            label,
        });
    }

    return sections;
};

const { folder, album } = Astro.params;

// Get all albums and find the matching one by its combined slug
const allAlbums = await getCollection("albums");
const albumEntry = allAlbums.find((a) => a.slug === `${folder}/${album}`);

if (!albumEntry) {
    return Astro.redirect("/404");
}

// Get the Content component from the entry
let Content;
try {
    console.log("Rendering album:", albumEntry.id, "Folder:", folder);
    const rendered = await albumEntry.render();
    Content = rendered.Content;
} catch (e) {
    console.error("Error rendering album:", e);
    throw e;
}

const titleSections = extractTitleSections(albumEntry.body);
---

<Layout title={`${albumEntry.data.title} - RIVERBED`}>
    <div class="fixed bottom-8 right-8 z-40 flex flex-col gap-3">
        <button
            class="album-tags-toggle group text-zinc-500 hover:text-white transition-all duration-300"
            id="toggle-all-tags"
            aria-label="Toggle all photo tags"
            data-active="false"
            data-visible="false"
            type="button"
        >
            <div
                class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center group-hover:border-white/30 transition-colors bg-white/20 backdrop-blur-sm"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path></svg
                >
            </div>
        </button>
        <button
            onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
            class="group text-zinc-500 hover:text-white transition-all duration-300 opacity-0 translate-y-4 pointer-events-none"
            id="back-to-top"
            aria-label="Scroll to top"
        >
            <div
                class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center group-hover:border-white/30 transition-colors bg-white/20 backdrop-blur-sm"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="m18 15-6-6-6 6"></path></svg
                >
            </div>
        </button>
        <button
            onclick="window.scrollTo({top: document.body.scrollHeight, behavior: 'smooth'})"
            class="group text-zinc-500 hover:text-white transition-all duration-300 opacity-0 translate-y-4 pointer-events-none"
            id="scroll-to-bottom"
            aria-label="Scroll to bottom"
        >
            <div
                class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center group-hover:border-white/30 transition-colors bg-white/20 backdrop-blur-sm"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="m6 9l6 6 6-6"></path></svg
                >
            </div>
        </button>
    </div>

    <div class="relative py-4">
        {titleSections.length > 0 && (
            <div class="pointer-events-none fixed left-8 top-28 z-30 hidden xl:block">
                <nav
                    aria-label="Album sections"
                    class="pointer-events-auto flex max-w-28 flex-col items-start gap-2 text-left"
                >
                    {titleSections.map((section) => (
                        <a
                            href={`#${section.id}`}
                            data-album-breadcrumb={section.id}
                            class="album-breadcrumb-link text-xs uppercase tracking-[0.18em] text-zinc-600 transition-colors duration-200 hover:text-zinc-200"
                        >
                            {section.label}
                        </a>
                    ))}
                </nav>
            </div>
        )}

        <div class="mb-8 text-center">
            <h1
                class="text-xl font-sans tracking-widest uppercase mb-1"
            >
                {albumEntry.data.title}
            </h1>
            {albumEntry.data.info && (
                <p class="text-sm text-zinc-500 font-light tracking-wider uppercase">
                    {albumEntry.data.info}
                </p>
            )}
        </div>

        <article
            class="album-content"
            style={albumEntry.data.gap ? `--album-block-gap: ${albumEntry.data.gap}` : undefined}
        >
            <Content components={{ Row, Photo, Text, PhotoCarousel }} />
        </article>
    </div>
</Layout>

<style>
    .album-content {
        width: 100%;
        display: flex;
        flex-direction: column;
    }

    /* Apply the gap to all blocks except the last one */
    .album-content > :global(*) {
        margin-bottom: var(--album-block-gap, 0.5rem);
    }

    .album-content > :global(*:last-child) {
        margin-bottom: 0;
    }

    .album-content :global(h2) {
        font-size: 1.5rem;
        font-weight: 600;
        margin: 2rem 0 1rem;
    }

    .album-content :global(.text-block--title) {
        scroll-margin-top: 7rem;
    }

    .album-content :global(p) {
        margin: 0.5rem 0;
        line-height: 1.6;
    }

    .album-breadcrumb-link[data-active="true"] {
        color: rgba(255, 255, 255, 0.9);
    }

    .album-tags-toggle {
        display: none;
    }

    .album-tags-toggle[data-active="true"] > div {
        background: rgba(37, 99, 235, 0.8);
        color: white;
        border-color: rgba(37, 99, 235, 0.95);
    }

    @media (max-width: 768px) and (hover: none) {
        .album-tags-toggle[data-visible="true"] {
            display: block;
        }
    }
</style>

<script>
    let breadcrumbObserver: IntersectionObserver | null = null;
    let areAllTagsVisible = false;

    const slugifySectionTitle = (value) => value
        .toLowerCase()
        .normalize("NFKD")
        .replace(/[\u0300-\u036f]/g, "")
        .replace(/[^a-z0-9\s-]/g, "")
        .trim()
        .replace(/\s+/g, "-") || "section";

    const initAlbumBreadcrumbs = () => {
        const titleNodes = Array.from(document.querySelectorAll(".album-content .text-block--title"));
        const breadcrumbLinks = Array.from(document.querySelectorAll("[data-album-breadcrumb]"));

        if (titleNodes.length === 0 || breadcrumbLinks.length === 0) {
            return;
        }

        const slugCounts = new Map();

        titleNodes.forEach((node, index) => {
            const label = node.textContent?.replace(/\s+/g, " ").trim() || `section-${index + 1}`;
            const baseSlug = slugifySectionTitle(label);
            const nextCount = (slugCounts.get(baseSlug) ?? 0) + 1;
            slugCounts.set(baseSlug, nextCount);

            node.id = nextCount === 1 ? baseSlug : `${baseSlug}-${nextCount}`;
        });

        const updateActiveBreadcrumb = (activeId) => {
            breadcrumbLinks.forEach((link) => {
                const isActive = link.getAttribute("data-album-breadcrumb") === activeId;
                link.toggleAttribute("data-active", isActive);
                link.setAttribute("aria-current", isActive ? "true" : "false");
            });
        };

        breadcrumbObserver?.disconnect();
        breadcrumbObserver = new IntersectionObserver(
            (entries) => {
                const visibleEntry = entries
                    .filter((entry) => entry.isIntersecting)
                    .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

                if (visibleEntry?.target instanceof HTMLElement) {
                    updateActiveBreadcrumb(visibleEntry.target.id);
                }
            },
            {
                rootMargin: "-20% 0px -60% 0px",
                threshold: [0.2, 0.6, 1],
            }
        );

        titleNodes.forEach((node) => breadcrumbObserver?.observe(node));
        if (titleNodes[0] instanceof HTMLElement) {
            updateActiveBreadcrumb(titleNodes[0].id);
        }
    };

    const syncAlbumTagToggle = () => {
        const toggleButton = document.getElementById("toggle-all-tags") as HTMLButtonElement | null;
        if (!toggleButton) return;

        const wrappers = Array.from(document.querySelectorAll(".photo-wrapper[data-has-tags='true']")) as HTMLElement[];
        const hasTags = wrappers.length > 0;

        toggleButton.dataset.visible = hasTags ? "true" : "false";
        if (!hasTags) {
            areAllTagsVisible = false;
            toggleButton.dataset.active = "false";
            return;
        }

        wrappers.forEach((wrapper) => {
            wrapper.classList.toggle("show-info", areAllTagsVisible);
        });
        toggleButton.dataset.active = areAllTagsVisible ? "true" : "false";
    };

    const initAlbumTagToggle = () => {
        const toggleButton = document.getElementById("toggle-all-tags") as HTMLButtonElement | null;
        if (!toggleButton) return;

        toggleButton.onclick = (event) => {
            event.preventDefault();
            areAllTagsVisible = !areAllTagsVisible;
            syncAlbumTagToggle();
        };

        syncAlbumTagToggle();
    };

    const handleScroll = () => {
        const backToTop = document.getElementById("back-to-top");
        const scrollToBottom = document.getElementById("scroll-to-bottom");

        if (backToTop) {
            if (window.scrollY > 300) {
                backToTop.classList.remove("opacity-0", "translate-y-4", "pointer-events-none");
                backToTop.classList.add("opacity-100", "translate-y-0", "pointer-events-auto");
            } else {
                backToTop.classList.add("opacity-0", "translate-y-4", "pointer-events-none");
                backToTop.classList.remove("opacity-100", "translate-y-0", "pointer-events-auto");
            }
        }

        if (scrollToBottom) {
            const isNearBottom = (window.scrollY + window.innerHeight) >= (document.documentElement.scrollHeight - 300);
            if (!isNearBottom) {
                scrollToBottom.classList.remove("opacity-0", "translate-y-4", "pointer-events-none");
                scrollToBottom.classList.add("opacity-100", "translate-y-0", "pointer-events-auto");
            } else {
                scrollToBottom.classList.add("opacity-0", "translate-y-4", "pointer-events-none");
                scrollToBottom.classList.remove("opacity-100", "translate-y-0", "pointer-events-auto");
            }
        }
    };

    window.addEventListener("scroll", handleScroll);
    document.addEventListener("astro:after-swap", handleScroll);
    document.addEventListener("astro:after-swap", initAlbumBreadcrumbs);
    document.addEventListener("astro:after-swap", initAlbumTagToggle);
    handleScroll();
    initAlbumBreadcrumbs();
    initAlbumTagToggle();
</script>
