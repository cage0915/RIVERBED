---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import {
    getFolderTitle,
    getFolderOrder,
    getImageUrl,
    R2_DOMAIN,
} from "../lib/constants";

// Get all albums and extract unique folders from their slugs
const albums = await getCollection("albums");

// Group albums by folder, sorted by album order descending
const folderMap = new Map<
    string,
    { coverUrl: string; fallbackUrl: string; title: string }[]
>();
for (const album of albums) {
    const folderSlug = album.slug.split("/")[0];
    if (!folderMap.has(folderSlug)) folderMap.set(folderSlug, []);
    folderMap.get(folderSlug)!.push({
        coverUrl: getImageUrl(album.data.coverKey),
        fallbackUrl: `${R2_DOMAIN}/${album.data.coverKey}`,
        title: album.data.title,
    });
}

const folderSlugs = [
    ...new Set(albums.map((album) => album.slug.split("/")[0])),
];
const isDev = import.meta.env.DEV;

const sortedFolders = folderSlugs
    .map((slug) => ({
        id: slug,
        title: getFolderTitle(slug),
        order: getFolderOrder(slug),
        covers: folderMap.get(slug) ?? [],
    }))
    .sort((a, b) => a.order - b.order);
---

<Layout title="RIVERBED">
    <main class="mx-auto px-2 py-8">
        <div class="folders-grid">
            {
                sortedFolders.map((folder) => (
                    <div
                        class="album-card group"
                        data-covers={folder.covers.length}
                    >
                        <a href={`/${folder.id}`} class="album-link">
                            <div class="album-cover">
                                {folder.covers.map((cover, i) => (
                                    <img
                                        src={cover.coverUrl}
                                        alt={cover.title}
                                        loading={i === 0 ? "eager" : "lazy"}
                                        class={`slide ${i === 0 ? "active" : ""}`}
                                        onerror={
                                            isDev
                                                ? `this.onerror=null; this.src='${cover.fallbackUrl}';`
                                                : undefined
                                        }
                                    />
                                ))}
                                <div class="album-overlay">
                                    <h2 class="album-title">{folder.title}</h2>
                                </div>
                            </div>
                        </a>
                    </div>
                ))
            }
        </div>
    </main>
</Layout>

<script>
    const INTERVAL_MS = 5000;

    const initFolderCards = () => {
        document
            .querySelectorAll<HTMLElement>(".album-card")
            .forEach((card) => {
                const slides =
                    card.querySelectorAll<HTMLImageElement>(".slide");
                if (slides.length <= 1) return;

                let current = 0;
                setInterval(() => {
                    slides[current].classList.remove("active");
                    current = (current + 1) % slides.length;
                    slides[current].classList.add("active");
                }, INTERVAL_MS);
            });

        // Mobile tap-to-reveal overlay (same as folder page)
        const cards = document.querySelectorAll(".album-card");
        cards.forEach((card) => {
            const link = card.querySelector(".album-link");
            card.addEventListener("click", (e) => {
                const isMobile = window.matchMedia(
                    "(max-width: 768px) and (hover: none)",
                ).matches;
                if (!isMobile) return;

                if (!card.classList.contains("show-info")) {
                    e.preventDefault();
                    cards.forEach((c) => c.classList.remove("show-info"));
                    card.classList.add("show-info");
                }
            });
        });

        document.addEventListener("click", (e) => {
            if (!(e.target as Element).closest(".album-card")) {
                cards.forEach((c) => c.classList.remove("show-info"));
            }
        });
    };

    initFolderCards();
    document.addEventListener("astro:after-swap", initFolderCards);
</script>

<style>
    .folders-grid {
        display: grid;
        grid-template-columns: repeat(var(--cols, 3), 1fr);
        gap: 0.5rem;
        margin: 0 auto;
    }

    @media (max-width: 1024px) {
        .folders-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 640px) {
        .folders-grid {
            grid-template-columns: 1fr;
        }
    }

    .album-card {
        position: relative;
    }

    .album-link {
        text-decoration: none;
        color: inherit;
        display: block;
    }

    .album-cover {
        position: relative;
        width: 100%;
        aspect-ratio: 16/9;
        overflow: hidden;
    }

    /* All slides stacked on top of each other */
    .album-cover .slide {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0;
        transition:
            opacity 0.8s ease,
            transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .album-cover .slide.active {
        opacity: 1;
    }

    .album-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        transition: all 0.4s ease;
        background: rgba(255, 255, 255, 0);
        opacity: 0;
        z-index: 10;
        pointer-events: none;
    }

    .album-title {
        font-family: "Noto Sans TC", "Noto Sans JP", sans-serif;
        font-size: 1.5rem;
        font-weight: 400;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-align: center;
        color: #111827;
        transform: translateY(10px);
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        z-index: 20;
    }

    .album-card.show-info .album-overlay {
        opacity: 1;
        background: rgba(255, 255, 255, 0.7);
    }

    .album-card.show-info .album-title {
        opacity: 1;
        transform: translateY(0);
    }

    @media (hover: hover) {
        .album-card:hover .slide.active {
            transform: scale(1.05);
        }

        .album-card:hover .album-overlay {
            opacity: 1;
            background: rgba(255, 255, 255, 0.6);
        }

        .album-card:hover .album-title {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
