---
import { getCollection } from "astro:content";
import { ViewTransitions } from "astro:transitions";
import { getFolderTitle, getFolderOrder, getFolderFooter, FOLDER_METADATA } from "../lib/constants";
import "@fontsource/noto-sans-jp/300.css";
import "@fontsource/noto-sans-jp/400.css";
import "@fontsource/noto-sans-jp/500.css";
import "@fontsource/noto-sans-jp/700.css";
import "@fontsource/pt-sans/400.css";
import "@fontsource/pt-sans/700.css";
import "@fontsource/noto-sans-tc/300.css";
import "@fontsource/noto-sans-tc/500.css";
import "@fontsource/noto-sans-tc/700.css";
import "photoswipe/dist/photoswipe.css";
import DevTool from "../components/DevTool.astro";

interface Props {
	title: string;
}

const { title } = Astro.props;

// Use FOLDER_METADATA keys as the base for navigation
const metadataSlugs = Object.keys(FOLDER_METADATA);

// Fetch unique folders from album slugs to catch any folders missing from metadata
const albums = await getCollection("albums");
const albumFolderSlugs = albums.map((album) => album.slug.split("/")[0]);

// Combine and get unique slugs
const folderSlugs = [...new Set([...metadataSlugs, ...albumFolderSlugs])];

const sortedFolders = folderSlugs
	.map((slug) => ({
		id: slug,
		title: getFolderTitle(slug),
		order: getFolderOrder(slug),
	}))
	.sort((a, b) => a.order - b.order);

// Get the current path to highlight active link
const currentPath = Astro.url.pathname;

// Determine current folder for footer
const currentFolderSlug = currentPath.split("/").filter(Boolean)[0];
const folderFooter = currentFolderSlug ? getFolderFooter(currentFolderSlug) : null;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="RIVERBED" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ViewTransitions />
	</head>
	<body
		class="bg-[#121212] text-zinc-100 min-h-screen antialiased selection:bg-white/20"
	>
		<nav
			id="navbar"
			class="fixed top-0 left-0 right-0 z-50 bg-[#121212]/80 transition-transform duration-300 ease-in-out"
		>
			<div class="mx-auto max-w-[1100px] px-4 sm:px-8 h-24 flex items-center relative">
				<!-- Menu Toggle - Mobile Only -->
				<button
					id="menu-toggle"
					class="sm:hidden p-1 text-zinc-400 hover:text-white transition-colors"
					aria-label="Toggle menu"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="20"
						height="20"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="menu-icon"
						><line x1="3" y1="12" x2="21" y2="12"></line><line
							x1="3"
							y1="6"
							x2="21"
							y2="6"></line><line x1="3" y1="18" x2="21" y2="18"
						></line></svg
					>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="20"
						height="20"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="close-icon hidden"
						><line x1="18" y1="6" x2="6" y2="18"></line><line
							x1="6"
							y1="6"
							x2="18"
							y2="18"></line></svg
					>
				</button>

				<!-- Navigation -->
				<div class="hidden sm:flex gap-8">
					{
						sortedFolders.map((folder) => {
							const isActive = currentPath === `/${folder.id}` || currentPath.startsWith(`/${folder.id}/`);
							return (
								<a
									href={`/${folder.id}`}
									class={`text-base font-sans tracking-wide transition-colors hover:text-white relative py-1 ${
										isActive
											? "text-white"
											: "text-zinc-400"
									}`}
								>
									<span class={folder.id === 'dalin' ? 'condensed-kanji' : ''}>
										{folder.title}
									</span>
									<span
										class={`absolute bottom-0 left-0 right-0 h-0.5 bg-white rounded-full transition-opacity duration-300 ${isActive ? 'opacity-100' : 'opacity-0'} ${folder.id === 'dalin' ? 'condensed-kanji' : ''}`}
									/>
								</a>
							);
						})
					}
				</div>

				<!-- Logo - Centered -->
				<div class="absolute left-1/2 -translate-x-1/2">
					<a
						href="/"
						class="text-3xl font-sans tracking-[0.2em] hover:text-white transition-colors"
					>
						RIVERBED
					</a>
				</div>
			</div>

				</div>
			</div>

			<!-- Mobile Navigation Dropdown -->
			<div
				id="mobile-menu"
				class="hidden sm:hidden border-t border-white/5 bg-[#121212]/95 backdrop-blur-xl overflow-hidden transition-all duration-300 ease-in-out max-h-0"
			>
				<div class="flex flex-row items-center p-4 gap-6 overflow-x-auto scrollbar-none mask-linear-right">
					{
						sortedFolders.map((folder) => {
							const isActive = currentPath === `/${folder.id}` || currentPath.startsWith(`/${folder.id}/`);
							return (
								<a
									href={`/${folder.id}`}
									class={`text-base font-sans tracking-wide transition-all whitespace-nowrap relative py-1 ${
										isActive
											? "text-white"
											: "text-zinc-400"
									}`}
								>
									<span class={folder.id === 'dalin' ? 'condensed-kanji' : ''}>
										{folder.title}
									</span>
									<span
										class={`absolute bottom-0 left-0 right-0 h-0.5 bg-white rounded-full transition-opacity duration-300 ${isActive ? 'opacity-100' : 'opacity-0'} ${folder.id === 'dalin' ? 'condensed-kanji' : ''}`}
									/>
								</a>
							);
						})
					}
				</div>
			</div>
		</nav>

		<main class="mx-auto max-w-[1100px] px-4 sm:px-8 pt-28 pb-20">
			<slot />
		</main>

		{folderFooter && (
			<footer class="py-12 border-t border-white/5">
				<div class="mx-auto max-w-[1100px] px-4 sm:px-8 text-center">
					<p
						class="text-zinc-500 font-sans tracking-[0.3em] text-sm"
					>
						{folderFooter}
					</p>
				</div>
			</footer>
		)}

        {import.meta.env.DEV && <DevTool />}

		<script>
			let lastScrollY = window.scrollY;
			let navElements = {
				navbar: null as HTMLElement | null,
				menuToggle: null as HTMLElement | null,
				mobileMenu: null as HTMLElement | null
			};

			function initNavbar() {
				navElements.navbar = document.getElementById("navbar");
				navElements.menuToggle = document.getElementById("menu-toggle");
				navElements.mobileMenu = document.getElementById("mobile-menu");

				if (!navElements.menuToggle || !navElements.mobileMenu) return;

				// Use a fresh listener by replacing the element (simplest for ViewTransitions)
				const oldToggle = navElements.menuToggle;
				const newToggle = oldToggle.cloneNode(true) as HTMLElement;
				oldToggle.parentNode?.replaceChild(newToggle, oldToggle);
				navElements.menuToggle = newToggle;

				newToggle.addEventListener("click", () => {
					const isExpanded = navElements.mobileMenu?.classList.contains("hidden");

					if (isExpanded) {
						navElements.mobileMenu?.classList.remove("hidden");
						void navElements.mobileMenu?.offsetWidth;
						navElements.mobileMenu!.style.maxHeight = "500px";
						newToggle.querySelector(".menu-icon")?.classList.add("hidden");
						newToggle.querySelector(".close-icon")?.classList.remove("hidden");
					} else {
						navElements.mobileMenu!.style.maxHeight = "0px";
						newToggle.querySelector(".menu-icon")?.classList.remove("hidden");
						newToggle.querySelector(".close-icon")?.classList.add("hidden");
						setTimeout(() => {
							if (navElements.mobileMenu!.style.maxHeight === "0px") {
								navElements.mobileMenu?.classList.add("hidden");
							}
						}, 300);
					}
				});
			}

			// Window listeners should be added ONCE
			window.addEventListener("scroll", () => {
				const currentScrollY = window.scrollY;
				const { navbar, mobileMenu, menuToggle } = navElements;

				if (mobileMenu && !mobileMenu.classList.contains("hidden")) {
					mobileMenu.style.maxHeight = "0px";
					menuToggle?.querySelector(".menu-icon")?.classList.remove("hidden");
					menuToggle?.querySelector(".close-icon")?.classList.add("hidden");
					setTimeout(() => {
						mobileMenu.classList.add("hidden");
					}, 300);
				}

				if (currentScrollY > lastScrollY && currentScrollY > 120) {
					navbar?.classList.add("-translate-y-full");
				} else {
					navbar?.classList.remove("-translate-y-full");
				}

				lastScrollY = currentScrollY;
			}, { passive: true });

			// Keyboard Navigation
			window.addEventListener("keydown", (e) => {
				if (
					e.key !== "ArrowRight" &&
					e.key !== "ArrowLeft" &&
					e.key !== "ArrowDown" &&
					e.key !== "ArrowUp"
				)
					return;

				const targets = Array.from(
					document.querySelectorAll(
						".photo-row, .album-card, .folder-card",
					),
				);
				if (targets.length === 0) return;

				const navbarHeight = 110;
				const scrollPadding = 20;
				const currentPos = window.scrollY + navbarHeight + scrollPadding;

				const nextIndex = targets.findIndex((t) => {
					const rect = t.getBoundingClientRect();
					return window.scrollY + rect.top > currentPos;
				});

				let target;
				if (e.key === "ArrowRight" || e.key === "ArrowDown") {
					if (nextIndex !== -1) target = targets[nextIndex];
				} else if (e.key === "ArrowLeft" || e.key === "ArrowUp") {
					const currentIndex = nextIndex === -1 ? targets.length : nextIndex;
					if (currentIndex > 1) {
						target = targets[currentIndex - 2];
					} else if (currentIndex === 1) {
						window.scrollTo({ top: 0, behavior: "smooth" });
						return;
					}
				}

				if (target) {
					const targetTop = window.scrollY + target.getBoundingClientRect().top - navbarHeight + 10;
					window.scrollTo({ top: targetTop, behavior: "smooth" });
					e.preventDefault();
				}
			});

			// PhotoSwipe Initialization
			import PhotoSwipeLightbox from "photoswipe/lightbox";

			let lightbox: PhotoSwipeLightbox | null = null;

			const initPhotoSwipe = () => {
				if (lightbox) {
					lightbox.destroy();
				}

				lightbox = new PhotoSwipeLightbox({
					gallery:
						".album-content, .tag-photos, .pswp-gallery, .prose",
					children: ".pswp-link",
					pswpModule: () => import("photoswipe"),
				});

				// Initialize dimensions on the fly if not provided
				lightbox.on("beforeOpen", () => {
					const links = document.querySelectorAll(
						".pswp-link",
					) as NodeListOf<HTMLAnchorElement>;
					links.forEach((link) => {
						const img = link.querySelector("img");
						if (
							img &&
							(!link.dataset.pswpWidth ||
								!link.dataset.pswpHeight)
						) {
							if (img.naturalWidth) {
								link.dataset.pswpWidth =
									img.naturalWidth.toString();
								link.dataset.pswpHeight =
									img.naturalHeight.toString();
							}
						}
					});
				});

				lightbox.init();
			};

			const initDimensions = () => {
				const links = document.querySelectorAll(
					".pswp-link",
				) as NodeListOf<HTMLAnchorElement>;
				links.forEach((link) => {
					const img = link.querySelector("img");
					if (img) {
						if (img.complete) {
							if (img.naturalWidth) {
								link.dataset.pswpWidth =
									img.naturalWidth.toString();
								link.dataset.pswpHeight =
									img.naturalHeight.toString();
							}
						} else {
							img.addEventListener("load", () => {
								link.dataset.pswpWidth =
									img.naturalWidth.toString();
								link.dataset.pswpHeight =
									img.naturalHeight.toString();
							});
						}
					}
				});
			};

			const initAll = () => {
				initNavbar();
				initDimensions();
				initPhotoSwipe();
			};

			initAll();
			document.addEventListener("astro:after-swap", initAll);
		</script>
	</body>
</html>

<style is:global>
	/* Elegant scrollbar */
	::-webkit-scrollbar {
		width: 8px;
	}
	::-webkit-scrollbar-track {
		background: #555555;
	}
	::-webkit-scrollbar-thumb {
		background: #27272a;
		border-radius: 4px;
	}
	::-webkit-scrollbar-thumb:hover {
		background: #3f3f46;
	}

	:root {
		font-family: "PT Sans", "Noto Sans TC", "Noto Sans JP", sans-serif;
		scrollbar-gutter: stable;
	}

	body {
		font-family: "PT Sans", "Noto Sans TC", "Noto Sans JP", sans-serif;
	}

	.condensed-kanji {
		display: inline-block;
		transform: scaleX(0.7);
		transform-origin: center;
		letter-spacing: -0.05em;
	}

	.mask-linear-right {
		mask-image: linear-gradient(to right, black 85%, transparent 100%);
	}

	@media (min-width: 640px) {
		.mask-none {
			mask-image: none;
		}
	}
</style>
