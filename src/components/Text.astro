---
interface Props {
  align?: 'left' | 'center' | 'right';
  size?: 'caption' | 'title';
  mt?: string;
  mb?: string;
}

const { align = 'left', size = 'title', mt = '2rem', mb = '0.5rem' } = Astro.props;

const style = [
  `margin-top: ${mt};`,
  `margin-bottom: ${mb};`,
  `text-align: ${align};`,
].join(' ');
---

<div class:list={["text-block", `text-block--${size}`]} style={style}>
  <slot />
</div>

<style>
  .text-block {
    width: 100%;
    font-family: "PT Sans", "Noto Sans TC", "Noto Sans JP", sans-serif;
  }

  /* caption size: same as photo-caption in Row.astro */
  .text-block--caption {
    font-size: 0.875rem;
    font-weight: 300;
    letter-spacing: 0.05em;
    color: white;
  }

  /* title size: slightly bigger, for section titles */
  .text-block--title {
    font-size: 1.125rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.72);
  }
</style>
