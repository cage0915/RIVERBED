                                <button id="dev-pm-add-block" style="width: 100%; padding: 0.6rem; border: 1px dashed #ccc; border-radius: 6px; background: #fff; cursor: pointer; font-size: 0.85rem; display: flex; align-items: center; justify-content: center; gap: 0.4rem;">
