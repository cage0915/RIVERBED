---
interface Props {
    cols?: number; // Optional now, kept for backward compatibility with existing .mdx
    mb?: string; // technical override
    mt?: string; // technical override
    blockMargin?: string; // semantic block gap
    captionMargin?: string; // semantic caption space
    caption?: string;
    captionPosition?: string; // e.g. "center top", "right bottom"
}

const {
    mb,
    mt,
    blockMargin,
    captionMargin,
    caption,
    captionPosition = "center bottom",
} = Astro.props;

const isDev = import.meta.env.DEV;

const parsedPos = captionPosition.includes('top') ? 'top' : 'bottom';
const parsedAlign = captionPosition.includes('left') ? 'left' : captionPosition.includes('right') ? 'right' : 'center';

const hasTopCaption = caption && parsedPos === 'top';
const hasBottomCaption = caption && parsedPos === 'bottom';

const styles = [];

// Determine final margins
const finalMT = mt || (hasTopCaption ? captionMargin : undefined);
const finalMB = mb || blockMargin || (hasBottomCaption ? captionMargin : undefined);

if (finalMT) {
    styles.push(`margin-top: ${finalMT} !important;`);
} else if (hasTopCaption) {
    styles.push("margin-top: 2rem;");
}

if (finalMB) {
    styles.push(`margin-bottom: ${finalMB} !important;`);
} else if (hasBottomCaption) {
    styles.push("margin-bottom: 2rem;");
}
---

<div
    class="row-wrapper"
    style={styles.length > 0 ? styles.join(" ") : undefined}
    data-dev-block={isDev ? "row" : undefined}
    data-dev-caption={isDev && caption ? caption : undefined}
    data-dev-caption-pos={isDev ? captionPosition : undefined}
    data-dev-mb={isDev && mb ? mb : undefined}
>
    {caption && parsedPos === 'top' && (
        <div class="photo-caption top" style={`text-align: ${parsedAlign};`}>
            {caption}
        </div>
    )}
    <div class="photo-row">
        <slot />
    </div>
    {caption && parsedPos === 'bottom' && (
        <div class="photo-caption bottom" style={`text-align: ${parsedAlign};`}>
            {caption}
        </div>
    )}
</div>

<style>
    .row-wrapper {
        width: 100%;
        display: flex;
        flex-direction: column;
    }

    .photo-row {
        display: flex;
        gap: 0.5rem;
        width: 100%;
    }

    .photo-row > :global(*) {
        /* Default to equal widths based on actual child count. Overridden by JS aspect ratios. */
        flex: 1 1 0%;
        min-width: 0;
    }

    .photo-caption {
        font-size: 0.875rem;
        color: #71717a;
    }

    .photo-caption.top {
        margin-bottom: 0.5rem;
    }

    .photo-caption.bottom {
        margin-top: 0.5rem;
    }

    @media (prefers-color-scheme: dark) {
        .photo-caption {
            color: #a1a1aa;
        }
    }
</style>

<script>
    const adjustRowHeights = () => {
        document.querySelectorAll('.photo-row').forEach(row => {
            const items = row.querySelectorAll('.photo-container, :scope > *');

            items.forEach(item => {
                const img = item.querySelector('img');
                if (!img) return;

                const applyRatio = () => {
                    if (img.naturalWidth && img.naturalHeight) {
                        const ratio = img.naturalWidth / img.naturalHeight;
                        // Multiply ratio by 100 to ensure the sum of flex-grow values in the row
                        // is always >= 1. If sum(flex-grow) < 1, Flexbox won't fill the full width!
                        // The relative proportions between items remain exactly the same.
                        (item as HTMLElement).style.flex = `${ratio * 100} 1 0%`;
                    }
                };

                if (img.complete) {
                    applyRatio();
                } else {
                    img.addEventListener('load', applyRatio);
                }
            });
        });
    };

    // Initialize on first load and re-run on Astro view transitions
    adjustRowHeights();
    document.addEventListener('astro:after-swap', adjustRowHeights);
</script>
