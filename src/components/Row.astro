---
interface Props {
    cols: number;
    padding?: string;
}

const { cols, padding = "0 0 0.5rem 0" } = Astro.props;
---

<div class="photo-row" style={`--cols: ${cols}; padding: ${padding};`}>
    <slot />
</div>

<style>
    .photo-row {
        display: flex;
        gap: 0.5rem;
        width: 100%;
    }

    .photo-row > :global(*) {
        flex: 0 0 calc((100% - (var(--cols) - 1) * 0.5rem) / var(--cols));
        min-width: 0;
    }
</style>
